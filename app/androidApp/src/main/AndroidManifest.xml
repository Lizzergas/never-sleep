<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required to change global screen timeout (Settings.System.SCREEN_OFF_TIMEOUT). -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS" />

    <!-- Required for loading ads (AdMob or other networks) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NeverSleep">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Quick Settings Tile (visible near WiFi, Airplane mode, etc.) -->
        <service
            android:name=".NeverSleepTileService"
            android:exported="true"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:label="Never Sleep">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- 1x1 Home screen widget -->
        <receiver
            android:name=".NeverSleepWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/never_sleep_widget_info" />
        </receiver>

        <!-- Receiver for widget clicks (to toggle without opening full app) -->
        <receiver
            android:name=".NeverSleepWidgetReceiver"
            android:exported="true" />
    </application>

</manifest>
