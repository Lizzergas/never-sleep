# Copy this file to keystore.properties (it is gitignored) and fill in your values.
# Then place your actual release keystore in the path you specify.

# How to generate a release keystore (run once):
# keytool -genkey -v -keystore keystores/never-sleep-release.keystore \
#   -alias never-sleep -keyalg RSA -keysize 2048 -validity 10000

# Path is relative to the repo root (see app/androidApp/build.gradle.kts signing block).
storeFile=keystores/never-sleep-release.keystore
storePassword=YOUR_STORE_PASSWORD_HERE
keyAlias=never-sleep
keyPassword=YOUR_KEY_PASSWORD_HERE

# After filling, run:
# ./gradlew :app:androidApp:bundleRelease
# or
# ./gradlew :app:androidApp:assembleRelease
