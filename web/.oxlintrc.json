{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "node_modules/**",
    "apps/*/dist/**",
    "apps/*/.astro/**",
    "apps/*/.vite/**",
    "packages/*/dist/**",
    "coverage/**",
    "playwright-report/**",
    "test-results/**",
    ".cache/**",
    ".turbo/**"
  ],
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  }
}
