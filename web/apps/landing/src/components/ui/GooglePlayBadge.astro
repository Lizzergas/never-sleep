---
interface Props {
    large?: boolean;
}

const { large = false } = Astro.props;
const PLAY_STORE_URL = "https://play.google.com/store/apps/details?id=com.lizz.neversleep";
---

<a
    class:list={["play-badge", large && "play-badge--large"]}
    href={PLAY_STORE_URL}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Get it on Google Play"
>
    <img
        src="/badges/en_badge_web_generic.png"
        alt="Get it on Google Play"
        width="646"
        height="250"
        loading="lazy"
        decoding="async"
    />
</a>