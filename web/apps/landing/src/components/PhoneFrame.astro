---
interface Props {
    src: string;
    alt: string;
    caption?: string;
    active?: boolean;
}

const { src, alt, caption, active = false } = Astro.props;
---

<figure class:list={["phone-frame", active && "phone-frame--active"]}>
    <div class="phone-frame__bezel">
        <div class="phone-frame__screen">
            <img src={src} alt={alt} width="270" height="600" loading="lazy" decoding="async" />
        </div>
    </div>
    {caption ? <figcaption>{caption}</figcaption> : null}
</figure>