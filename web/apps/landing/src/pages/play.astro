---
import SiteLayout from "../layouts/SiteLayout.astro";
import "../styles/site.css";

const shortDescription =
    "Keep your screen awake — one tap, Quick Settings tile, and home-screen widget.";
const fullDescription = `Never Sleep prevents your Android screen from turning off due to inactivity.

• One-tap toggle — big, beautiful button to switch between normal and never-sleep mode
• Quick Settings tile — toggle without opening the app
• Home-screen widget — 1×1 widget for instant access
• Restores your previous timeout when you turn it off

The app uses Android's "Modify system settings" permission to change screen-off timeout. You grant this once in system Settings. Battery use may increase while enabled — disable anytime.

Optional banner ads support development. Disable ads in Settings.

Privacy policy: https://neversleep.app/privacy`;
---

<SiteLayout
    title="Google Play Listing — Never Sleep"
    description="Store listing copy, assets checklist, and Play Console URLs for Never Sleep."
>
    <article class="doc">
        <p class="kicker">Google Play</p>
        <h1>Play Store listing</h1>
        <p class="lede">
            Copy-paste fields for Play Console. Deploy this site to
            <code>https://neversleep.app</code> and use the privacy URL below.
        </p>

        <section class="listing-card">
            <h2>Store URLs</h2>
            <dl class="listing-meta">
                <div>
                    <dt>Privacy policy URL</dt>
                    <dd><a href="/privacy">https://neversleep.app/privacy</a></dd>
                </div>
                <div>
                    <dt>Application ID</dt>
                    <dd><code>com.lizz.neversleep</code></dd>
                </div>
                <div>
                    <dt>Category</dt>
                    <dd>Tools</dd>
                </div>
            </dl>
        </section>

        <section class="listing-card">
            <h2>Short description</h2>
            <p class="copy-block">{shortDescription}</p>
            <p class="hint">{shortDescription.length} / 80 characters max</p>
        </section>

        <section class="listing-card">
            <h2>Full description</h2>
            <pre class="copy-block">{fullDescription}</pre>
        </section>

        <section class="listing-card">
            <h2>Graphics checklist</h2>
            <ul>
                <li>App icon — <code>assets/play-store/icon-512.png</code> (512×512)</li>
                <li>Phone screenshots — <code>assets/play-store/screenshots/</code></li>
                <li>Feature graphic — <code>assets/play-store/feature-graphic.png</code> (1024×500)</li>
            </ul>
        </section>

        <section class="listing-card">
            <h2>Host neversleep.app (GitHub Pages)</h2>
            <ol>
                <li>
                    GitHub repo → <strong>Settings → Pages</strong> → Build and deployment:
                    <strong>GitHub Actions</strong>
                </li>
                <li>
                    Push to <code>main</code> — workflow <code>deploy-landing.yml</code> builds
                    <code>web/apps/landing</code> and publishes <code>dist/</code>
                </li>
                <li>
                    In Hostinger → <strong>DNS / Nameservers</strong> for <code>neversleep.app</code>,
                    add:
                    <pre class="copy-block">A     @    185.199.108.153
A     @    185.199.109.153
A     @    185.199.110.153
A     @    185.199.111.153
CNAME www  lizzergas.github.io</pre>
                </li>
                <li>GitHub → Pages → Custom domain → <code>neversleep.app</code> (CNAME file ships in the build)</li>
                <li>Enable <strong>Enforce HTTPS</strong> after DNS propagates (often under an hour)</li>
            </ol>
            <p class="hint">
                Local asset preview (all graphics for Play upload):
                open <code>assets/play-store/preview.html</code> in a browser.
            </p>
        </section>

        <section class="listing-card">
            <h2>AdMob</h2>
            <dl class="listing-meta">
                <div>
                    <dt>App ID</dt>
                    <dd><code>ca-app-pub-5214975738753935~5698552370</code></dd>
                </div>
                <div>
                    <dt>Banner unit</dt>
                    <dd><code>ca-app-pub-5214975738753935/4818761149</code></dd>
                </div>
            </dl>
        </section>

        <section class="listing-card">
            <h2>Data safety (summary)</h2>
            <ul>
                <li>No account registration</li>
                <li>App activity: optional ad interactions via AdMob (declare per AdMob / Google guidance)</li>
                <li>Device identifiers: may be collected by AdMob when ads enabled</li>
                <li>Data encrypted in transit (AdMob SDK)</li>
                <li>Users can disable ads in-app</li>
            </ul>
        </section>
    </article>
</SiteLayout>