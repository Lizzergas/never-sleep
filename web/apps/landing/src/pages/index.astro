---
import SiteLayout from "../layouts/SiteLayout.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import GooglePlayBadge from "../components/ui/GooglePlayBadge.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import PhoneFrame from "../components/PhoneFrame.astro";

const description =
    "Prevent your screen from turning off due to inactivity. One tap to enable screen lock and you are good to go!";
---

<SiteLayout showShader={true} title="Never Sleep — Android screen timeout utility" description={description}>
    <section class="hero" aria-labelledby="page-title">
        <div class="hero__copy">
            <div class="hero__badge">
                <span class="hero__badge-dot" aria-hidden="true"></span>
                Screen stays on until you turn it off
            </div>
            <h1 id="page-title">Never Sleep</h1>
            <p class="lede">{description}</p>
            <div class="actions" aria-label="Primary links">
                <GooglePlayBadge />
                <Button href="/privacy" variant="secondary">Privacy policy</Button>
            </div>
        </div>

        <div class="hero__phones" aria-label="App screenshots">
            <PhoneFrame
                src="/screenshots/01-normal.png"
                alt="Never Sleep app in normal screen timeout mode"
                caption="Normal mode"
            />
            <PhoneFrame
                src="/screenshots/02-never-sleep.png"
                alt="Never Sleep app with screen kept awake"
                caption="Never sleep mode"
                active={true}
            />
        </div>
    </section>

    <section aria-labelledby="features-title">
        <SectionHeading
            title="Built for quick control"
            description="Three ways to toggle — same simple idea: your screen stays awake only when you want it to."
        />
        <div class="feature-grid">
            <Card class="feature-card">
                <div class="feature-card__icon" aria-hidden="true">◎</div>
                <h3 id="features-title">One-tap toggle</h3>
                <p>A large, clear button in the app switches between normal and never-sleep mode instantly.</p>
            </Card>
            <Card class="feature-card">
                <div class="feature-card__icon" aria-hidden="true">▣</div>
                <h3>Quick Settings tile</h3>
                <p>Toggle without opening the app — add the tile once and control timeout from the shade.</p>
            </Card>
            <Card class="feature-card">
                <div class="feature-card__icon" aria-hidden="true">◫</div>
                <h3>Home-screen widget</h3>
                <p>A minimal 1×1 widget for instant access from your launcher.</p>
            </Card>
        </div>
    </section>

    <section class="cta-band" aria-label="Download">
        <div>
            <h2>Ready when you need it</h2>
            <p>Restores your previous timeout automatically when you turn Never Sleep off.</p>
        </div>
        <GooglePlayBadge />
    </section>
</SiteLayout>