---
import SiteLayout from "../layouts/SiteLayout.astro";
import "../styles/site.css";
---

<SiteLayout
    title="Never Sleep — Android screen timeout utility"
    description="Keep your Android screen awake with one tap, a Quick Settings tile, and a home-screen widget."
>
    <section class="hero" aria-labelledby="page-title">
        <div class="hero-copy">
            <p class="kicker">Android utility</p>
            <h1 id="page-title">Never Sleep</h1>
            <p class="lede">
                Prevent your screen from turning off due to inactivity. One tap, a Quick Settings
                tile, and a 1×1 widget — then restore your previous timeout when you are done.
            </p>
            <div class="actions" aria-label="Primary links">
                <a href="/play">Play Store listing</a>
                <a href="/privacy">Privacy policy</a>
            </div>
        </div>

        <div class="preview-panel app-preview" aria-label="App preview">
            <div class="preview-header">
                <span></span>
                <span></span>
                <span></span>
            </div>
            <div class="app-mock">
                <p class="mock-title">never sleep</p>
                <div class="mock-button" aria-hidden="true">🌙</div>
                <p class="mock-caption">Tap to toggle · Tile · Widget</p>
            </div>
        </div>
    </section>
</SiteLayout>