root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
max_line_length = 120
ktlint_standard_filename = disabled
# Disabled because ktlint's official rule prefers splitting some assignments
# that this template intentionally keeps as `val x = listOf(` when it fits.
# The repo-specific Gradle `kotlinAssignmentWrapping*` tasks enforce that style.
ktlint_standard_multiline-expression-wrapping = disabled
# Compose: composables are PascalCase functions
ktlint_function_naming_ignore_when_annotated_with = Composable
# Allow wildcard imports off (default) but keep trailing commas as written
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

[*.{yml,yaml,json}]
indent_size = 2
